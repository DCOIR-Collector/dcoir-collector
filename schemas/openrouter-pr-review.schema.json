{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DCOIR PR Review Detector Findings",
  "type": "object",
  "additionalProperties": false,
  "required": ["summary", "findings"],
  "properties": {
    "summary": {
      "type": "string",
      "description": "Brief review summary for the PR review body."
    },
    "findings": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "title",
          "severity",
          "confidence",
          "path",
          "line",
          "body",
          "suggested_replacement",
          "validation"
        ],
        "properties": {
          "title": {
            "type": "string",
            "maxLength": 120
          },
          "severity": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low"]
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "path": {
            "type": "string",
            "description": "Repository-relative path for the finding."
          },
          "line": {
            "type": "integer",
            "minimum": 1,
            "description": "Line number on the RIGHT side of the PR diff when possible."
          },
          "body": {
            "type": "string",
            "description": "Concise explanation of the problem, why it matters, and the smallest safe patch direction when a fix is obvious."
          },
          "suggested_replacement": {
            "type": "string",
            "description": "Detector/review passes must return an empty string. Native GitHub suggestion text is generated only by the separate fix-synthesis schema after deterministic anchoring checks."
          },
          "validation": {
            "type": "string",
            "description": "Exact validation command or commands that should pass after the fix."
          }
        }
      }
    }
  }
}
