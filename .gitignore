__pycache__/
*.pyc
.DS_Store

# ChatGPT GitHub Staging Lane transient workspace.
# Keep request/in/out/apply_reports tracked intentionally; ignore only scratch work.
chatgpt_staging/work/

# ChatGPT exec artifacts are uploaded as GitHub Actions artifacts and may contain
# long generated paths that break Windows checkout. Keep heartbeat/report files
# in Git; do not commit unzipped exec artifact readback trees.
chatgpt_staging/status_reports/chatgpt-exec/*/artifact_readback/

# DCOIR generated validation outputs
project_sources/validation/out_*/
project_sources/TestResults/

# Gemini behavioral harness blind/generated artifacts
project_sources/gemini/fixtures/behavioral_replay/blind_artifacts/**
!project_sources/gemini/fixtures/behavioral_replay/blind_artifacts/.gitkeep
!project_sources/gemini/fixtures/behavioral_replay/blind_artifacts/collector_fixture179_t2_sanitized/
!project_sources/gemini/fixtures/behavioral_replay/blind_artifacts/collector_fixture179_t2_sanitized/**
project_sources/gemini/fixtures/behavioral_replay/blind/**/response_packs/

# Collector blind fixture artifacts are operator-supplied or generated locally.
project_sources/collector/fixtures/blind_artifacts/**
!project_sources/collector/fixtures/blind_artifacts/.gitkeep

# Workflow reporter generated local output
chatgpt_workflow_report_section/
