{
    "id":  "tblNsjkGUUIdRpHuE",
    "name":  "DCOIR Lifecycle Ledger",
    "description":  "Canonical lifecycle-history ledger for DCOIR Airtable objects that move through intake, planning, work execution, checkpointing, queue state, and migration/cleanup events. This table is a readback/history surface, not the live task authority. Use Work Items for executable work, Plans for parent scope, Session Checkpoints for resume continuity, and Delete Queue for deletion workflow. Inspect field descriptions before writing records. New scripts should set event_key, source_table, source_record_id, lifecycle_object_type, lifecycle_stage, event_at, migration_status, created_at, and retention_class explicitly.",
    "primaryFieldId":  "fldan2IfSl6NUJbre",
    "fields":  [
                   {
                       "type":  "singleLineText",
                       "id":  "fldan2IfSl6NUJbre",
                       "name":  "event_key",
                       "description":  "Purpose: Stable unique lifecycle event key used for deduplication and readback verification. Type: single-line text. Default: none; scripts must set explicitly."
                   },
                   {
                       "type":  "singleLineText",
                       "id":  "fld3eMKRitqiB7UCI",
                       "name":  "source_table",
                       "description":  "Purpose: Source Airtable table name for the lifecycle event. Type: single-line text. Default: none; scripts must set explicitly. Keep text because source tables may evolve."
                   },
                   {
                       "type":  "singleLineText",
                       "id":  "fldYjWKeshXjIhk01",
                       "name":  "source_record_id",
