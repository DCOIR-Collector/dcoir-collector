{
  "tool": "New-DcoirAirtableDatabaseHealthExport.ps1",
  "recommended_first_run": {
    "schema_only": true,
    "redact_likely_secrets": true,
    "max_records_per_table": 10
  },
  "environment_variables": {
    "required_machine_scope": [
      "DCOIR_REPO_ROOT",
      "DCOIR_DOWNLOADS_DIR",
      "DCOIR_AIRTABLE_API_TOKEN",
      "DCOIR_AIRTABLE_BASE_ID"
    ],
    "optional_machine_scope": [
      "DCOIR_AIRTABLE_TABLES"
    ]
  },
  "outputs": [
    "diagnostic_index.md",
    "export_manifest.json",
    "schema/schema.summary.json",
    "schema/schema.base_tables.json",
    "schema/table.<table>.<id>.schema.json",
    "records/table.<table>.<id>.records.json when not schema-only",
    "*.chatgpt.zip"
  ],
  "safety": {
    "read_only_airtable": true,
    "token_value_written_to_output": false,
    "use_redact_likely_secrets_for_record_exports": true,
    "cleanup_recommendations_require_delete_queue": true
  }
}
