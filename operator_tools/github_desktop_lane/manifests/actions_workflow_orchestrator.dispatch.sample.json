{
  "run_set_id": "dcoir-two-workflow-live-test-sample",
  "mode": "dispatch",
  "repo": "malwaredevil/dcoir-collector",
  "default_ref": "main",
  "dry_run": true,
  "require_dispatch_confirmation": true,
  "poll_interval_seconds": 30,
  "timeout_minutes": 90,
  "max_parallel": 1,
  "output": {
    "folder": "%DCOIR_DOWNLOADS_DIR%",
    "create_chatgpt_friendly_zip": true,
    "download_artifacts": true,
    "zip_name": "dcoir_actions_workflow_orchestrator_sample.chatgpt.zip"
  },
  "runs": [
    {
      "run_id": "collector-quick-validation",
      "workflow": "manual-full-validation.yml",
      "ref": "main",
      "inputs": {
        "suite": "QuickAliases"
      },
      "capture": {
        "summary": true,
        "jobs": true,
        "logs": true,
        "artifacts": true
      }
    },
    {
      "run_id": "optional-exe-session-validation",
      "workflow": "manual-collector-optional-exe-build.yml",
      "ref": "main",
      "inputs": {
        "exe_validation_suite": "SessionBehavior"
      },
      "capture": {
        "summary": true,
        "jobs": true,
        "logs": true,
        "artifacts": true
      }
    }
  ]
}