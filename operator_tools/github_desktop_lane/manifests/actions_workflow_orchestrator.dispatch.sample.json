{
  "run_set_id": "dcoir-actions-dispatch-dry-run-sample",
  "mode": "dispatch",
  "repo": "DCOIR-Collector/dcoir-collector",
  "default_ref": "main",
  "dry_run": true,
  "require_dispatch_confirmation": true,
  "allow_multiple_live_dispatches": false,
  "max_dispatch_count": 1,
  "poll_interval_seconds": 30,
  "timeout_minutes": 60,
  "max_parallel": 1,
  "output": {
    "folder": "%DCOIR_DOWNLOADS_DIR%",
    "create_chatgpt_friendly_zip": true,
    "download_artifacts": false,
    "zip_name": "dcoir_actions_workflow_orchestrator_sample.chatgpt.zip"
  },
  "runs": [
    {
      "run_id": "collector-quick-validation",
      "workflow": "manual-full-validation.yml",
      "ref": "main",
      "inputs": {
        "suite": "QuickAliases"
      },
      "capture": {
        "summary": true,
        "jobs": true,
        "logs": true,
        "artifacts": false
      }
    }
  ]
}
