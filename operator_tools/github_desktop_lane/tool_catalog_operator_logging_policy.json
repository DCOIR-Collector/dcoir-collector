{
  "catalog_policy_id": "DCOIR-OPERATOR-TOOL-LOGGING-DEFAULT",
  "updated_at": "2026-05-03T15:10:00Z",
  "applies_to": "DCOIR operator-side PowerShell tools and generated local-execution codeblocks",
  "default_module": "operator_tools/github_desktop_lane/modules/Dcoir.Logging/Dcoir.Logging.psm1",
  "operator_tools_registry_id": "DCOIR-OPERATOR-TOOL-LOGGING",
  "work_item_id": "WI-20260503-OPERATOR-TOOL-LOGGING-DEFAULT-ENFORCEMENT",
  "policy": {
    "one_uploadable_log_file_required_by_default": true,
    "return_log_path_on_success": true,
    "return_log_path_on_failure": true,
    "screenshots_are_not_primary_diagnostic_output": true,
    "ad_hoc_script_local_logging_should_not_be_created_when_module_import_is_possible": true,
    "exceptions_must_be_explicit": true
  },
  "required_log_contents": [
    "tool name",
    "tool version",
    "logging module version",
    "current directory",
    "log path",
    "resolved paths",
    "safe configuration presence/source",
    "phase transitions",
    "validation checks",
    "counts or hashes when useful",
    "error message",
    "error type",
    "stack trace when available",
    "next action"
  ],
  "secret_handling": {
    "print_secret_environment_values": false,
    "print_token_values": false,
    "allowed": "log variable names, presence, source, safe paths, hashes, counts, and non-secret operational state"
  },
  "first_consumer": "operator_tools/github_desktop_lane/scripts/New-DcoirApplyInPayload.ps1",
  "notes": "This small policy file exists so future sessions can discover the logging default without needing this chat context or rewriting the large tool_catalog.json."
}
